#include <iostream>      // Подключаем ввод/вывод
using namespace std;     // Чтобы писать cout, endl без std::

class apartament {            // класс квартира
private:                      // Закрытые  поля — инкапсуляция
    int people;                 // Количество жильцов
    int numberapartament;          // Номер квартиры
    double area;                    // Площадь квартиры
    double money;            // Долг по квартире 
public:                            // Открытые  методы
    apartament();                  // Конструктор без параметров
    apartament(int ludi, int chislo , double sq, double dolg);
                                 // Конструктор с параметрами
    void printInfo();             //  вывод информации о квартире
    bool hasdolg();            //  проверить, есть ли долг
};

// Реализация конструктора по умолчанию
apartament::apartament() {
    people = 0;                  // Жильцов 0
    numberapartament = 0;       // Номер по умолчанию 0
    area = 0.0;                 // Площадь 0
    money = 0.0;               // Долг  0
}

// Реализация конструктора с параметрами
apartament::apartament(int ludi, int chislo , double sq, double dolg) {
    people = ludi;                     // Устанавливаем количество жильцов
    numberapartament = chislo;          // Устанавливаем номер квартиры
    area = sq;                             // Устанавливаем площадь
    money = dolg;                  // Устанавливаем сумму долга
}

// Метод вывода информации о квартире
void apartament::printInfo(){
    cout << "кв" << numberapartament << " " << people << "чел " 
         << area << "м^2 долг" << money << "руб" << endl;
}

// Метод который возвращает true/false, есть ли долг
bool apartament::hasdolg(){
    return money > 0;   // true, если долг больше 0
}

int main() {
    apartament a1;                            // Создаём квартиру a1 (все значения по 0)
    apartament a2(3,46,89.7,13767);        // Создаём квартиру a2 с заданными данными
    
    cout << "первая квартира" << endl;
    a1.printInfo();                       // Выводим данные по a1
    
    cout << "вторая квартира" << endl;
    a2.printInfo();                       // Выводим данные по a2
    
    return 0;                       // конец
}
